# Caddyfile - Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

{
  # ACME configuration
  email {{ caddy_acme_email | default('admin@' + app_domain) }}
}

# Redirect www to non-www
www.{{ app_domain }} {
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }
  redir https://{{ app_domain }}{uri} permanent
}

# Reverse proxy to application
{{ app_domain }} {
  # Use Cloudflare DNS challenge for TLS certificates
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }

  # Reverse proxy to application container
  reverse_proxy app:3001 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }

  # Security headers
  header {
    # HSTS
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Prevent MIME type sniffing
    X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    X-Frame-Options "SAMEORIGIN"

    # XSS protection
    X-XSS-Protection "1; mode=block"

    # Referrer policy
    Referrer-Policy "strict-origin-when-cross-origin"

    # Remove server header
    -Server
  }

  # Client upload size limit
  request_body {
    max_size {{ caddy_client_max_body_size | default('100M') }}
  }

  # JSON access logs for fail2ban
  log {
    output file /var/log/caddy/access.log {
      roll_size 100mb
      roll_keep 5
      roll_keep_for 720h
    }
    format json
  }
}
