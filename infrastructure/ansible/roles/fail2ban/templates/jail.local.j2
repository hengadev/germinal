# Fail2ban Jail Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY

[DEFAULT]
ignoreip = {{ fail2ban_ignoreip | default('127.0.0.1/8 ::1') }}
bantime = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
destemail = {{ fail2ban_notify_email }}
sender = fail2ban@localhost
action = %(action_mwl)s

[sshd]
enabled = {{ 'true' if fail2ban_enabled else 'false' }}
port = {{ ssh_port }}
filter = sshd
logpath = /var/log/auth.log
maxretry = {{ fail2ban_ssh_maxretry }}
bantime = {{ fail2ban_ssh_bantime }}
findtime = {{ fail2ban_findtime }}

[sshd-ddos]
enabled = {{ 'true' if fail2ban_enabled else 'false' }}
port = {{ ssh_port }}
filter = sshd[mode=ddos]
logpath = /var/log/auth.log
maxretry = {{ fail2ban_ddos_maxretry }}
bantime = {{ fail2ban_ddos_bantime }}
findtime = {{ fail2ban_findtime }}

{% if caddy_enabled | default(false) %}
[caddy-rate-limit]
enabled = true
port = http,https
filter = caddy-rate-limit
logpath = {{ caddy_data_dir }}/logs/access.log
maxretry = {{ fail2ban_caddy_maxretry }}
bantime = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
{% endif %}
