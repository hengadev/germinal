# {{ app_name }} - Reverse Proxy Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY

# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name {{ app_domain }} www.{{ app_domain }};

    # Allow Let's Encrypt ACME challenges
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect everything else to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ app_domain }} www.{{ app_domain }};

    # SSL Configuration
    # When using Cloudflare proxy, you can use their origin certificates
    # Or use Let's Encrypt for self-managed certificates
    {% if nginx_ssl_certificate | default(false) %}
    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};
    {% else %}
    # Placeholder certificates - replace with actual certs
    # For Cloudflare Origin Certificate: upload to /etc/ssl/cloudflare/
    ssl_certificate /etc/ssl/cloudflare/{{ app_domain }}.pem;
    ssl_certificate_key /etc/ssl/cloudflare/{{ app_domain }}.key.pem;
    {% endif %}

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Client body size limit (for file uploads)
    client_max_body_size {{ nginx_client_max_body_size | default('100M') }};

    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # Rate limiting
    limit_req zone=general burst=20 nodelay;
    limit_conn addr 10;

    # Application proxy
    location / {
        proxy_pass http://127.0.0.1:{{ app_port }};
        proxy_http_version 1.1;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # Disable buffering for real-time responses
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Media files (optional: serve directly from S3 via CloudFront)
    location /media/ {
        proxy_pass https://{{ nginx_media_cdn | default('media.' + app_domain) }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;
    }

    # Health check endpoint (no auth required)
    location /health {
        proxy_pass http://127.0.0.1:{{ app_port }}/health;
        access_log off;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to common backup and config files
    location ~* \.(env|log|sql|bak|backup|old|orig|save|swp)$ {
        deny all;
        access_log off;
        log_not_found off;
    }
}

