# Terraform Variables Example
# Copy this file to terraform.tfvars and update with your values

# AWS region for resources
aws_region = "eu-central-1"

# Project name (used for resource naming)
project_name = "germinal"

# Deployment environment
environment = "development"

# Allowed CORS origins for S3 uploads
# Add your production domain here when ready
allowed_origins = [
  "http://localhost:5173",
  "http://localhost:4100",
  "https://your-domain.com",
]

# Set to false after initial backend setup
create_backend_resources = true

# ============================================
# Hetzner Cloud Configuration
# ============================================

# Hetzner Cloud API token
# Get yours from: https://console.hetzner.cloud/projects/YOUR_PROJECT_ID/security/tokens
hcloud_token = "your_hetzner_api_token_here"

# Server type (cpx11 = 2GB RAM, ~€4/mo; cpx21 = 4GB RAM, ~€8/mo; cpx31 = 8GB RAM, ~€15/mo)
server_type = "cpx11"

# Datacenter location (nbg1 = Nuremberg, fsn1 = Falkenstein, hil = Hilversum/NL)
server_location = "nbg1"

# Server OS image
server_image = "ubuntu-24.04"

# SSH public key for server access
# Get your public key with: cat ~/.ssh/id_rsa.pub
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... your_email@example.com"

# Enable automatic backups (additional 20% of server price)
enable_backups = true

# ============================================
# Cloudflare DNS Configuration
# ============================================

# Cloudflare API token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone - DNS - Edit
cloudflare_token = "your_cloudflare_api_token_here"

# Cloudflare Zone ID for your domain
# Found in the Cloudflare dashboard: Domain -> Overview -> scroll down to "API" section
cloudflare_zone_id = "your_zone_id_here"

# Your domain name
domain_name = "example.com"

# Contact email for DMARC reports (usually your email or admin email)
contact_email = "admin@example.com"

# Google Site Verification (optional)
# Get from Google Search Console if you need to verify your domain
# Leave empty if not needed
google_site_verification = ""

# ============================================
# Email Configuration (Hostinger Business Email + Amazon SES API)
# ============================================
# SENDING: Amazon SES via AWS SDK (uses same IAM credentials as S3)
#   - No SMTP credentials needed; app calls SES API directly
#   - Only manual step: request SES production access in AWS Console
#
# RECEIVING: Hostinger Business Email
#   - Create mailbox in hPanel (e.g., support@yourdomain.com)
#   - Get DKIM records from hPanel > Emails > Email DNS Records

# MX servers (Hostinger defaults)
email_mx_primary          = "mx1.hostinger.com"
email_mx_primary_priority = 10

email_mx_secondary          = "mx2.hostinger.com"
email_mx_secondary_priority = 20

# SPF includes — add providers that send on your behalf
# Default includes amazonses.com; add Hostinger if they require it
email_spf_includes = ["amazonses.com"]

# DMARC policy (none, quarantine, reject)
email_dmarc_policy = "quarantine"

# Hostinger DKIM records (3 standard CNAME records)
# See: https://www.hostinger.com/support/4456413
# Or in hPanel: Emails > Manage > Connect Domain > Increase email deliverability
email_dkim_records = {
  "hostingermail-a._domainkey" = {
    type    = "CNAME"
    content = "hostingermail-a.dkim.mail.hostinger.com"
  }
  "hostingermail-b._domainkey" = {
    type    = "CNAME"
    content = "hostingermail-b.dkim.mail.hostinger.com"
  }
  "hostingermail-c._domainkey" = {
    type    = "CNAME"
    content = "hostingermail-c.dkim.mail.hostinger.com"
  }
}

# ============================================
# Twilio Configuration
# ============================================
# Terraform creates two API keys in one apply: staging-germinal-app and production-germinal-app.
# The Auth Token is used only here (to authenticate with Twilio) and never written to the VPS.
# Get from: https://console.twilio.com -> Account -> Account Info
#
# IMPORTANT: use Twilio TEST credentials (separate Account SID + Auth Token from the Twilio
# Console test section) so the staging API key cannot send real SMS.

twilio_account_sid             = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
twilio_auth_token              = "your_twilio_auth_token_here"
twilio_phone_number_production = "+your_production_twilio_number"
# Staging always uses +15005550006 (Twilio magic test number) — no variable needed.

# ============================================
# Database Backup Configuration
# ============================================

# Number of days to retain daily backups (7-365)
# Weekly backups are retained for 2x this value
# Monthly backups are retained for 1 year
backup_retention_days = 90
