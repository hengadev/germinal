# Terraform Variables Example
# Copy this file to terraform.tfvars and update with your values

# AWS region for resources
aws_region = "eu-central-1"

# Project name (used for resource naming)
project_name = "germinal"

# Deployment environment
environment = "development"

# Allowed CORS origins for S3 uploads
# Add your production domain here when ready
allowed_origins = [
  "http://localhost:5173",
  "http://localhost:4100",
  "https://your-domain.com",
]

# Set to false after initial backend setup
create_backend_resources = true

# ============================================
# Hetzner Cloud Configuration
# ============================================

# Hetzner Cloud API token
# Get yours from: https://console.hetzner.cloud/projects/YOUR_PROJECT_ID/security/tokens
hcloud_token = "your_hetzner_api_token_here"

# Server type (cpx11 = 2GB RAM, ~€4/mo; cpx21 = 4GB RAM, ~€8/mo; cpx31 = 8GB RAM, ~€15/mo)
server_type = "cpx11"

# Datacenter location (nbg1 = Nuremberg, fsn1 = Falkenstein, hil = Hilversum/NL)
server_location = "nbg1"

# Server OS image
server_image = "ubuntu-24.04"

# SSH public key for server access
# Get your public key with: cat ~/.ssh/id_rsa.pub
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... your_email@example.com"

# Enable automatic backups (additional 20% of server price)
enable_backups = true

# ============================================
# Cloudflare DNS Configuration
# ============================================

# Cloudflare API token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone - DNS - Edit
cloudflare_token = "your_cloudflare_api_token_here"

# Cloudflare Zone ID for your domain
# Found in the Cloudflare dashboard: Domain -> Overview -> scroll down to "API" section
cloudflare_zone_id = "your_zone_id_here"

# Your domain name
domain_name = "example.com"

# Contact email for DMARC reports (usually your email or admin email)
contact_email = "admin@example.com"

# Google Site Verification (optional)
# Get from Google Search Console if you need to verify your domain
# Leave empty if not needed
google_site_verification = ""
