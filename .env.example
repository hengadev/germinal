# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/germinal

# Mock Data Configuration (required when USE_MOCK_DATA=true)
# Admin credentials are required; staff credentials are optional.
# MOCK_ADMIN_EMAIL=your@email.com
# MOCK_ADMIN_PASSWORD=yourpassword
# MOCK_STAFF_EMAIL=staff@email.com
# MOCK_STAFF_PASSWORD=yourpassword
USE_MOCK_DATA=false

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=germinal-media
S3_PUBLIC_URL=https://germinal-media.s3.amazonaws.com

# Application Configuration
PUBLIC_URL=http://localhost:5173
NODE_ENV=development
PORT=3000

# Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime

# SMTP Configuration (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@germinal.com
SMTP_FROM_NAME=Germinal
CONTACT_EMAIL=hello@germinal.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Reservation Configuration
RESERVATION_EXPIRY_MINUTES=15

# Cron Security (required in production, min 32 characters)
CRON_SECRET=change-me-to-a-secure-random-string-min-32-chars

# Twilio SMS Configuration (optional, for SMS notifications)
# Use API keys instead of the Auth Token for scoped, revocable credentials.
# In production/staging these are managed by Terraform (make credentials in infrastructure/terraform).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here
TWILIO_PHONE_NUMBER=+1234567890

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn_here
USE_SCHEDULER=false
